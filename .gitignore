# DbDuo .gitignore
#
# Files matching these patterns are NOT tracked in source control.
# They are either transient build artifacts, dev-only convenience
# scripts that are not distributed to users, or backup files from
# editors.
#
# Note: DbDuo.exe and DbDuo_setup.exe are intentionally NOT excluded;
# they ARE tracked in this repo. DbDuo_setup.exe is also published as
# a GitHub Release asset by tagRelease.ps1. End users can either
# download the .exe from the source-tree view or get the latest from
# the Releases page.

# ---- Build logs and scratch ---------------------------------------
# buildDbDuo.cmd writes a fresh log on each run.
buildDbDuo.log

# tagRelease.ps1 / tagRelease.cmd write timestamped logs.
tagRelease-*.log

# Inno Setup compiler scratch (if any). The setup .exe itself lives
# at the repo root and IS tracked.
*.iss.bak

# Compiler debug symbol files. We do not build with debug symbols
# (/optimize+ /debug-) but keep this pattern defensive in case a
# developer runs a debug build locally.
*.pdb

# ---- Development-only scripts (NOT distributed) -------------------
# tagRelease.* are convenience scripts for the maintainer's release
# workflow. They invoke `git tag`, `git push`, and `gh release` based
# on the AppVersion in DbDuo_setup.iss. End users do not need them
# and they are not part of any release zip. Keep them on the
# developer's disk but do not track them in git so they cannot leak
# into a release tag or be visible in the GitHub source browser.
tagRelease.cmd
tagRelease.ps1

# ---- Editor / IDE scratch -----------------------------------------
# Visual Studio / MSBuild leftovers (no longer used after the v1.0.44
# rollback to bare csc.exe, but these patterns are kept defensive in
# case a developer opens the project in VS).
bin/
obj/
packages/
*.suo
*.user
.vs/

# csproj / App.config from the v1.0.42-v1.0.43 MSBuild era. Removed
# in v1.0.44 but explicitly ignored so a stale dev checkout that
# still has them won't accidentally re-commit them.
DbDuo.csproj
App.config

# Backup files some editors leave behind.
*~
*.bak
*.tmp
*.swp

# Windows file-system clutter.
Thumbs.db
desktop.ini
