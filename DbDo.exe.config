<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <!-- DbDo targets .NET Framework 4.8; v4.0.30319 is the 4.x CLR. -->
    <supportedRuntime version="v4.0.30319"/>
  </startup>
  <runtime>
    <!-- Skip Authenticode publisher-evidence generation at startup. Without
         this, the CLR can stall for seconds while Windows checks certificate
         revocation lists (CRLs), especially on machines that are offline or
         behind a slow proxy. Safe to disable for a desktop database manager
         and a noticeable launch-time win. -->
    <generatePublisherEvidence enabled="false"/>
    <!-- Concurrent (background) GC keeps the UI responsive during collections;
         it is the default for workstation apps, stated here explicitly. -->
    <gcConcurrent enabled="true"/>
  </runtime>
</configuration>
